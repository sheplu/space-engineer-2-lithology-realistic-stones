{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheplu/space-engineer-2-lithology-realistic-stones/main/schemas/resource-stone.schema.json",
  "title": "SE2 Lithology Stone Record",
  "description": "Record shape for entries in data/stones.json — distinct rock types (igneous, sedimentary, metamorphic) that yield a mix of base-game raw resources when processed. Mirrors the shape of Mineralogy's ore record so tooling can be shared.",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "family",
    "type",
    "mass_kg",
    "volume_liters",
    "stackable",
    "divisible",
    "description",
    "gameStatus",
    "locations",
    "composition",
    "wiki",
    "dataGaps"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "snake_case stable key."
    },
    "displayName": { "type": "string" },
    "family": {
      "type": "string",
      "enum": ["igneous", "sedimentary", "metamorphic"],
      "description": "Rock family — informational, used for grouping/UX."
    },
    "type": {
      "type": "string",
      "enum": ["stone", "material"]
    },
    "mass_kg": { "type": ["number", "null"], "minimum": 0 },
    "volume_liters": { "type": ["number", "null"], "minimum": 0 },
    "stackable": { "type": "boolean" },
    "divisible": { "type": "boolean" },
    "description": { "type": ["string", "null"] },
    "gameStatus": {
      "type": "string",
      "enum": ["active", "disabled", "planned"]
    },
    "locations": {
      "type": "object",
      "required": ["planets", "asteroidFields"],
      "properties": {
        "planets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "biomes"],
            "properties": {
              "name": { "type": "string" },
              "biomes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "asteroidFields": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "composition": {
      "type": "array",
      "minItems": 1,
      "description": "Breakdown of base-game raw resources produced per unit of this stone. Percentages must sum to 1.0 (enforced by the validator).",
      "items": {
        "type": "object",
        "required": ["resourceId", "percentage"],
        "properties": {
          "resourceId": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$",
            "description": "ID from the base game's raw-resources.json (stone, silicon, magnesium, iron, ...)."
          },
          "percentage": {
            "type": "number",
            "exclusiveMinimum": 0,
            "maximum": 1,
            "description": "Fraction (0, 1]. Sum across all entries must equal 1.0."
          }
        }
      }
    },
    "wiki": { "type": "string", "format": "uri" },
    "dataGaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
