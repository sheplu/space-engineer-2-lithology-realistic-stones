{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/sheplu/space-engineer-2-lithology-realistic-stones/main/schemas/index.schema.json",
  "title": "SE2 Lithology Dataset Index",
  "type": "object",
  "required": ["version", "generatedAt", "game", "mod", "datasets"],
  "properties": {
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "generatedAt": { "type": "string", "format": "date" },
    "game": {
      "type": "object",
      "required": ["name", "stage", "dataAsOf"],
      "properties": {
        "name": { "type": "string" },
        "stage": { "type": "string" },
        "dataAsOf": { "type": "string", "format": "date" }
      }
    },
    "mod": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
      }
    },
    "notes": { "type": "string" },
    "totalEntries": { "type": "integer", "minimum": 0 },
    "datasets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "path", "category", "description", "version", "entryCount"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "path": { "type": "string" },
          "category": { "type": "string" },
          "subcategory": { "type": "string" },
          "description": { "type": "string" },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "entryCount": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
